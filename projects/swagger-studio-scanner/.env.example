# Copy to .env and fill in. .env is gitignored.

# Org-owner read key from https://app.swaggerhub.com/settings/apiKey
SWAGGERHUB_API_KEY=

# Organization (owner) slug to scan
SWAGGERHUB_ORG=

# SaaS default. Override only if on-prem (not applicable to this org).
SWAGGERHUB_BASE_URL=https://api.swaggerhub.com

# Optional tuning
SCANNER_CONCURRENCY=8
SCANNER_REQUEST_TIMEOUT_S=30
SCANNER_LOG_LEVEL=INFO
